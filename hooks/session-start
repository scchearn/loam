#!/usr/bin/env bash
# SessionStart hook for loam plugin (Claude Code, Cursor, Copilot).
#
# Reads loam::using SKILL.md from the npx skills install path (single source
# of truth): project-scoped first ($PWD/.agents/skills/), then global
# ($HOME/.agents/skills/). Strips frontmatter, wraps in <LOAM_IMPORTANT>,
# and emits platform-specific JSON additionalContext.
#
# Uses <LOAM_IMPORTANT> wrapper and "You have loam" marker to avoid
# collision with superpowers' injection.
#
# Output formats:
#   Cursor  -> additional_context (snake_case)
#   Claude  -> hookSpecificOutput.additionalContext (nested)
#   Copilot -> additionalContext (top-level, SDK standard)

set -euo pipefail

# Determine plugin root directory from script location (for package.json version).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read plugin version from package.json.
PLUGIN_VERSION=""
if [ -f "${PLUGIN_ROOT}/package.json" ]; then
  PLUGIN_VERSION=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${PLUGIN_ROOT}/package.json" | head -1)
fi

# Find loam::using SKILL.md: project-scoped first, then global.
SKILL_PATH=""
for candidate in "${PWD}/.agents/skills/loam-using/SKILL.md" "${HOME}/.agents/skills/loam-using/SKILL.md"; do
  if [ -f "$candidate" ]; then
    SKILL_PATH="$candidate"
    break
  fi
done

if [ -z "$SKILL_PATH" ]; then
  echo '[loam] loam::using not found — run: npx skills add scchearn/loam' >&2
  # Emit empty valid JSON so the session doesn't break.
  if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": ""\n}\n'
  elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": ""\n  }\n}\n'
  else
    printf '{\n  "additionalContext": ""\n}\n'
  fi
  exit 0
fi

# Read loam::using content
using_loam_content=$(cat "$SKILL_PATH" 2>&1 || echo "Error reading loam::using skill")

# Strip YAML frontmatter (---\n...\n---\n) if present.
strip_frontmatter() {
  local s="$1"
  if [[ "$s" =~ ^---$'\n'(.*)$'\n'---$'\n'(.*)$ ]]; then
    printf '%s' "${BASH_REMATCH[2]}"
  else
    printf '%s' "$s"
  fi
}

using_loam_content=$(strip_frontmatter "$using_loam_content")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

using_loam_escaped=$(escape_for_json "$using_loam_content")
VERSION_SUFFIX=""
if [ -n "$PLUGIN_VERSION" ]; then
  VERSION_SUFFIX=" (v${PLUGIN_VERSION})"
fi
session_context="<LOAM_IMPORTANT>\nYou have loam${VERSION_SUFFIX}.\n\n**IMPORTANT: The loam::using skill content is included below. It is ALREADY LOADED - you are currently following it. Do NOT use the skill tool to load 'loam::using' again - that would be redundant.**\n\n${using_loam_escaped}\n</LOAM_IMPORTANT>"

# Emit only the field the current platform consumes.
# Claude Code reads BOTH additional_context and hookSpecificOutput without
# deduplication, so we must emit only one.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT)
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT without COPILOT_CLI
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Copilot CLI (sets COPILOT_CLI=1) or unknown platform — SDK standard format
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0