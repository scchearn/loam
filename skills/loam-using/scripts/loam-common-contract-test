#!/usr/bin/env bash
# Contract test for loam-common.sh :: validate_wiki_root
# Sources the lib and exercises the wiki-root contract against 4 fixtures.
set -uo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/loam-common.sh"

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

fail() { echo "loam-common contract: FAIL: $1" >&2; exit 1; }

# 1. Contract file in a wiki/ subdir → probe that subdir directly → 0
mkdir -p "$tmp/with-wiki/wiki"
: > "$tmp/with-wiki/wiki/SCHEMA.md"
validate_wiki_root "$tmp/with-wiki/wiki" 2>/dev/null \
  || fail "fixture 1: expected 0 for resolved wiki subdir"

# 2. Contract file at the root itself → 0
mkdir -p "$tmp/with-wiki-root-here"
: > "$tmp/with-wiki-root-here/SCHEMA.md"
validate_wiki_root "$tmp/with-wiki-root-here" 2>/dev/null \
  || fail "fixture 2: expected 0 for root-level contract"

# 3. Contract one level down but caller passed the parent → 2 + "did you mean" hint
mkdir -p "$tmp/with-wiki-not-resolved/wiki"
: > "$tmp/with-wiki-not-resolved/wiki/SCHEMA.md"
err=$(validate_wiki_root "$tmp/with-wiki-not-resolved" 2>&1) && \
  fail "fixture 3: expected non-zero when contract is in wiki/ subdir"
grep -Fq 'did you mean' <<< "$err" || fail "fixture 3: expected 'did you mean' hint, got: $err"

# 4. Nonexistent path → 2 + "wiki root not found"
err=$(validate_wiki_root "$tmp/nonexistent" 2>&1) && \
  fail "fixture 4: expected non-zero for nonexistent path"
grep -Fq 'wiki root not found' <<< "$err" || fail "fixture 4: expected 'wiki root not found', got: $err"

echo "loam-common contract: PASS"
