#!/usr/bin/env bash
# Smoke test for loamstate.sh aggregate output under adversarial input.
# Proves the JSON stays valid when checkpoint titles contain quotes, git_status
# is multi-line, and a checkpoint is malformed (missing heading / scope), and
# that the advisory `hints` array covers the v1 kinds under cheap evidence.
set -uo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
LOAMSTATE="$SCRIPT_DIR/loamstate-legacy.sh"

command -v python3 >/dev/null 2>&1 || { echo "loamstate contract: SKIP (python3 not found)"; exit 0; }

tmp=$(mktemp -d)
tmp_empty=$(mktemp -d)
tmp_code=$(mktemp -d)
trap 'rm -rf "$tmp" "$tmp_empty" "$tmp_code"' EXIT

# Workspace is a git repo so git_status populates.
git -C "$tmp" init -q
git -C "$tmp" config user.email test@test
git -C "$tmp" config user.name test

mkdir -p "$tmp/wiki/checkpoints"
: > "$tmp/wiki/SCHEMA.md"

# Newest (latest_checkpoint): real checkpoint shape — `# Checkpoint` constant
# header, descriptive title under `### ` (primary workstream), Captured, but
# NO Scope → title populated from `### `, scope:null.
# Exercises the missing-Scope degrade AND the `### `-primary extraction.
cat > "$tmp/wiki/checkpoints/checkpoint-2026-07-03-1100.md" <<'NOTE'
# Checkpoint

- Captured: 2026-07-03 11:00 +02:00
- Reason: pause

## Workstreams

### Worker Cancellation Guard
- Status: ready-to-resume
- Next: add a guard at the start of run_pipeline_task
NOTE

# Fixture 5 (middle): heading contains a literal double-quote.
# `### ` carries the descriptive title; `# ` is the constant "Checkpoint".
# → recent_checkpoints[1].title round-trips the quote through JSON.
cat > "$tmp/wiki/checkpoints/checkpoint-2026-07-02-1000.md" <<'NOTE'
# Checkpoint

- Captured: 2026-07-02 10:00 +02:00
- Reason: pause
- Scope: worker/tasks/run_pipeline.py

## Workstreams

### Pipeline "cancel" bug
- Status: ready-to-resume
- Next: fix it
NOTE

# Fixture 7 (oldest): malformed — no "# " or "### " heading marker at all.
# → title:null, no crash. (Field extraction is gated on the heading, matching
#   the checkpoint-verify contract, so captured_at is null too — that's fine.)
cat > "$tmp/wiki/checkpoints/checkpoint-2026-07-01-0900.md" <<'NOTE'
Checkpoint (no heading marker)

- Captured: 2026-07-01 09:00 +02:00
- Reason: pause
NOTE

# Fixture 6: multi-line git_status — two untracked files (plus wiki/).
: > "$tmp/file-a.txt"
: > "$tmp/file-b.txt"

# --- Hint fixtures (cheap-evidence v1 kinds) ---
# legacy_structure_pending: overview.md present.
: > "$tmp/wiki/overview.md"
# log_rotation_due + memory_lint_stale: log.md >500 lines, no lint-check marker.
yes x 2>/dev/null | head -n 501 > "$tmp/wiki/log.md"
# retrieval_not_ready: metadata present but status != ready.
printf '{"retrieval":{"status":"indexing","collection_name":"t"}}' > "$tmp/wiki/.wiki-metadata.json"
# date_drift_pending: a page with a bare (offset-less) frontmatter timestamp.
cat > "$tmp/wiki/note.md" <<'NOTE'
---
updated_at: 2026-07-01 10:00
---
body
NOTE
# workflow: approved spec with no plan → spec_ready_for_plan; pending plan → plan_ready_to_start.
mkdir -p "$tmp/specs" "$tmp/plans"
printf -- '---\nstatus: approved\napproved_at: 2026-07-01 09:00 +02:00\n---\n' > "$tmp/specs/thing.md"
printf -- '---\nstatus: pending\n---\n' > "$tmp/plans/other.md"

out=$("$LOAMSTATE" "$tmp")

python3 - "$out" <<'PY' || exit 1
import json, sys
raw = sys.argv[1]
data = json.loads(raw)  # fixtures 5 & 6: throws if escaping broke the JSON

lc = data["latest_checkpoint"]
assert lc is not None, "latest_checkpoint should not be null"
assert lc["title"] == "Worker Cancellation Guard", f"latest title should come from ### not #: {lc['title']!r}"
assert lc["scope"] is None, f"missing Scope should be null, got {lc['scope']!r}"
assert lc["captured_at"] == "2026-07-03 11:00 +02:00", f"captured_at wrong: {lc['captured_at']!r}"

rc = data["recent_checkpoints"]
assert len(rc) == 3, f"expected 3 recent checkpoints, got {len(rc)}"
assert rc[1]["title"] == 'Pipeline "cancel" bug', f"quote-in-title did not round-trip from ###: {rc[1]['title']!r}"
assert "scope" not in rc[1], "recent_checkpoints entries must not carry scope"
assert rc[2]["title"] is None, f"headingless checkpoint title should be null, got {rc[2]['title']!r}"

assert data["checkpoint_count"] == 3, f"checkpoint_count wrong: {data['checkpoint_count']}"

gs = data["git_status"]
assert isinstance(gs, str) and "\n" in gs, f"git_status should be a multi-line string, got {gs!r}"

# --- Hint contract ---
hints = data["hints"]
assert isinstance(hints, list), f"hints must be an array, got {type(hints)}"
for h in hints:
    for k in ("kind", "group", "severity", "message", "command", "evidence"):
        assert k in h, f"hint missing field {k}: {h}"
    assert h["group"] in ("maintenance", "workflow"), f"bad group: {h['group']}"
    assert h["severity"] in ("info", "warn", "action"), f"bad severity: {h['severity']}"
    assert h["command"] is None or isinstance(h["command"], str)
    assert isinstance(h["evidence"], dict)

kinds = {h["kind"] for h in hints}
# The four cheap maintenance signals must ALL fire (AC 136 AND-semantics).
for want in ("date_drift_pending", "retrieval_not_ready", "log_rotation_due", "legacy_structure_pending"):
    assert want in kinds, f"expected maintenance hint {want}; got {sorted(kinds)}"
# checkpoint_stale: dirty worktree + old checkpoint.
assert "checkpoint_stale" in kinds, f"expected checkpoint_stale; got {sorted(kinds)}"
# At least one workflow hint from specs/plans probes.
assert kinds & {"spec_ready_for_plan", "plan_ready_to_start", "plan_in_progress", "resume_available", "resume_stale"}, \
    f"expected a workflow hint; got {sorted(kinds)}"

print("loamstate contract: hints PASS")
PY

# --- memory_missing: empty workspace emits exists:false + memory_missing hint ---
out_empty=$("$LOAMSTATE" "$tmp_empty")
python3 - "$out_empty" <<'PY' || exit 1
import json, sys
data = json.loads(sys.argv[1])
assert data["exists"] is False, "empty workspace should be exists:false"
kinds = {h["kind"] for h in data["hints"]}
assert "memory_missing" in kinds, f"expected memory_missing hint; got {sorted(kinds)}"
print("loamstate contract: memory_missing PASS")
PY

# --- probe-failure tolerance: wiki/code present but no index → codegraph probe
#     runs and may fail; JSON must stay valid and exit 0 regardless. ---
mkdir -p "$tmp_code/wiki/code"
: > "$tmp_code/wiki/SCHEMA.md"
out_code=$("$LOAMSTATE" "$tmp_code")
python3 - "$out_code" <<'PY' || exit 1
import json, sys
data = json.loads(sys.argv[1])  # throws if a failing probe corrupted the JSON
assert data["exists"] is True
assert isinstance(data["hints"], list)
print("loamstate contract: probe-failure tolerance PASS")
PY

# --- flat installed layout: codegraph.sh is a sibling of loam-using (not under
#     loam-memory/). Copy loamstate into a fake flat tree with a stub codegraph
#     and confirm code_ingest_pending still resolves. ---
flat=$(mktemp -d)
mkdir -p "$flat/loam-using/scripts" "$flat/loam-ingesting-codebase/scripts"
cp "$LOAMSTATE" "$flat/loam-using/scripts/loamstate-legacy.sh"
cat > "$flat/loam-ingesting-codebase/scripts/codegraph-legacy.sh" <<'STUB'
#!/usr/bin/env bash
# stub: only the `diff` subcommand is exercised; report one new file.
[[ "${1:-}" == "diff" ]] && echo '[{"path":"a.py","mtime":"1","reason":"new"}]'
exit 0
STUB
chmod +x "$flat/loam-ingesting-codebase/scripts/codegraph-legacy.sh"
ws_flat=$(mktemp -d)
mkdir -p "$ws_flat/wiki/code"
: > "$ws_flat/wiki/SCHEMA.md"
out_flat=$("$flat/loam-using/scripts/loamstate-legacy.sh" "$ws_flat")
rm -rf "$flat" "$ws_flat"
python3 - "$out_flat" <<'PY' || exit 1
import json, sys
data = json.loads(sys.argv[1])
kinds = {h["kind"] for h in data["hints"]}
assert "code_ingest_pending" in kinds, \
    f"flat-layout codegraph-legacy.sh must resolve → code_ingest_pending; got {sorted(kinds)}"
print("loamstate contract: flat-install codegraph PASS")
PY

echo "loamstate contract: PASS"
