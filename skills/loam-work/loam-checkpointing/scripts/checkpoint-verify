#!/bin/sh
# checkpoint-verify — compatibility forwarder to `loam checkpoint verify`.
#
# Usage:
#   checkpoint-verify <note.md>
#
# Verification itself always exits 0: a self-check must never block a save.
# The launcher can still report 75 (runtime not yet available) or 78
# (unsupported target), exactly as every other forwarded Loam script does.
#
# The full Bash implementation this replaced lives in checkpoint-verify-legacy
# and is retained only as parity evidence until the native runtime is published.
set -u
case "$0" in
  /*) SCRIPT_DIR=${0%/*} ;;
  */*) SCRIPT_DIR=$PWD/${0%/*} ;;
  *) SCRIPT_DIR=$PWD ;;
esac

# The generic launcher lives in the loam-using base skill; both the nested and
# flat install layouts are supported.
for candidate in \
  "$SCRIPT_DIR/../../../loam-using/scripts/loam.sh" \
  "$SCRIPT_DIR/../../loam-using/scripts/loam.sh"; do
  if [ -f "$candidate" ]; then
    exec "$candidate" checkpoint verify "$@"
  fi
done
echo "Error: loam launcher not found near: $SCRIPT_DIR" >&2
exit 1
