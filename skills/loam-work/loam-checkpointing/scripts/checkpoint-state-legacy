#!/usr/bin/env bash
# checkpoint-state — capture-side digest of hcom threads, taskwarrior items, recently-touched files
# Usage: checkpoint-state [--window MINUTES]   (default window: 180)
set -euo pipefail

WINDOW=180
if [ "${1:-}" = "--window" ] && [ -n "${2:-}" ]; then
    WINDOW="$2"
fi

command -v jq >/dev/null 2>&1 && HAVE_JQ=1 || HAVE_JQ=0
CUTOFF_ISO=$(date -d "$WINDOW minutes ago" +%Y-%m-%dT%H:%M:%S 2>/dev/null || date -d "-$WINDOW minutes" +%Y-%m-%dT%H:%M:%S)

# ---------------------------------------------------------------------------
# 1) hcom threads
# ---------------------------------------------------------------------------
echo "=== hcom threads ==="
if command -v hcom >/dev/null 2>&1; then
    # Try with jq first
    if [ "$HAVE_JQ" = 1 ]; then
        hcom_events=$(hcom events --last 500 2>/dev/null) || hcom_events=$(hcom events --last 200 2>/dev/null)
        if [ -n "$hcom_events" ]; then
            # Use ISO string comparison: ISO 8601 timestamps ARE lexicographically sortable
            echo "$hcom_events" | jq -sr --arg cutoff "$CUTOFF_ISO" '
                [.[] | select(.type == "message" and .data.thread != null and .ts >= $cutoff)]
                | group_by(.data.thread)
                | map({thread: .[0].data.thread, latest: (. | max_by(.ts))})
                | map({thread: .thread, id: .latest.id, intent: .latest.data.intent, sender: .latest.data.from})
                | sort_by(.thread)
                | .[]
                | "\(.thread) | msg #\(.id) | intent: \(.intent) | from: \(.sender)"
            ' 2>/dev/null
            # TODO: pending detection — v1 lists threads with last message; agent judges pendingness
        fi
    else
        # Fallback: parse text output for thread names
        hcom events --last 200 2>/dev/null | grep -oP '"thread":"[^"]*"' | sort -u | sed 's/"thread":"//;s/"//' | while IFS= read -r thread; do
            echo "$thread | - | - | -"
        done
    fi
else
    echo "hcom: not available"
fi

echo ""

# ---------------------------------------------------------------------------
# 2) taskwarrior active
# ---------------------------------------------------------------------------
echo "=== taskwarrior active ==="
if command -v task >/dev/null 2>&1; then
    if [ "$HAVE_JQ" = 1 ]; then
        task status:pending export 2>/dev/null | jq -r '
            .[:10][] | [.uuid, (.project // "none"), (.description[:60])] | @tsv
        ' 2>/dev/null || echo "  (no pending tasks or export failed)"
    else
        echo "task: not available (install jq for structured output)"
    fi
else
    echo "task: not available"
fi

echo ""

# ---------------------------------------------------------------------------
# 3) files touched recently
# ---------------------------------------------------------------------------
echo "=== files touched recently ==="
WORKSPACE="${WORKSPACE:-$PWD}"
# -mmin -N = modified less than N minutes ago
# Exclude hidden directories (dotfiles)
recent_count=0
while IFS= read -r -d '' f; do
    recent_count=$((recent_count + 1))
    [ "$recent_count" -gt 15 ] && break
    modtime=$(date -r "$f" "+%Y-%m-%d %H:%M" 2>/dev/null)
    echo "$modtime $f"
done < <(find "$WORKSPACE" -not -path '*/\.*' -mmin "-${WINDOW}" -type f -print0 2>/dev/null)

if [ "$recent_count" -eq 0 ]; then
    echo "none"
fi

exit 0