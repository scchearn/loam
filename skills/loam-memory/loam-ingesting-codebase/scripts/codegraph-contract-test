#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
SKILL_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
REPO_ROOT=$(cd -- "$SKILL_DIR/../../.." && pwd)
CODEGRAPH="$SCRIPT_DIR/codegraph.sh"
INGEST_SKILL="$SKILL_DIR/SKILL.md"
LOAM_COMMON="$REPO_ROOT/skills/loam-using/scripts/loam-common.sh"

stat_epoch() {
  stat -c %Y "$1" 2>/dev/null || stat -f %m "$1"
}

stat_size() {
  stat -c %s "$1" 2>/dev/null || stat -f %z "$1"
}

file_hash() {
  sha256sum "$1" 2>/dev/null | awk '{print $1}' || shasum -a 256 "$1" 2>/dev/null | awk '{print $1}'
}

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

codebase="$tmp/codebase"
wiki="$tmp/wiki"
mkdir -p "$codebase/src" "$wiki/code"
mkdir -p "$codebase/wiki/entities"

cat > "$codebase/.gitignore" <<'EOF'
ignored.ts
EOF
cat > "$codebase/wiki/SCHEMA.md" <<'EOF'
# Schema
EOF
cat > "$wiki/SCHEMA.md" <<'EOF'
# Schema
EOF

if command -v git >/dev/null 2>&1; then
  git -C "$codebase" init -q
fi

cat > "$codebase/src/current.ts" <<'EOF'
export const current = 1;
EOF
cat > "$codebase/src/stale.ts" <<'EOF'
export const stale = 1;
EOF
cat > "$codebase/src/legacy.ts" <<'EOF'
export const legacy = 1;
EOF
cat > "$codebase/src/new.ts" <<'EOF'
export const fresh = 1;
EOF
cat > "$codebase/src/semantic.py" <<'EOF'
VALUE = 1
EOF
cat > "$codebase/src/Button.svelte" <<'EOF'
<script>
  export let label;
</script>
<button>{label}</button>
EOF
cat > "$codebase/ignored.ts" <<'EOF'
export const ignored = true;
EOF
: > "$codebase/src/empty.ts"
printf '   \n\t\n' > "$codebase/src/blank.ts"
cat > "$codebase/src/generated.ts" <<'EOF'
// Code generated by tool. DO NOT EDIT.
export const generated = true;
EOF
python3 - <<PY
from pathlib import Path
root = Path('$codebase/src')
root.joinpath('large.ts').write_text('x' * 600000)
root.joinpath('binary.ts').write_bytes(b'abc\x00def')
PY

# Root-level excluded directories — **/dir/** must match dir at codebase root, not only nested
mkdir -p "$codebase/node_modules/dummy" "$codebase/dist"
cat > "$codebase/node_modules/dummy/index.js" <<'EOF'
export const dummy = 1;
EOF
cat > "$codebase/dist/build.js" <<'EOF'
export const built = 1;
EOF

touch -d '2026-06-20 10:00:00' "$codebase/src/current.ts"
touch -d '2026-06-24 16:53:00' "$codebase/src/stale.ts"
touch -d '2026-06-24 12:00:00' "$codebase/src/legacy.ts"
touch -d '2026-06-24 10:00:00' "$codebase/src/new.ts"

# Installed skills are flat siblings (loam-ingesting-codebase next to loam-using),
# unlike the repo source layout where this skill lives under skills/loam-memory/.
flat="$tmp/flat-skills"
mkdir -p "$flat/loam-ingesting-codebase/scripts" "$flat/loam-ingesting-codebase/references" "$flat/loam-using/scripts"
cp "$CODEGRAPH" "$flat/loam-ingesting-codebase/scripts/codegraph.sh"
cp "$SKILL_DIR/references/ingestion-exclusions.md" "$flat/loam-ingesting-codebase/references/ingestion-exclusions.md"
cp "$LOAM_COMMON" "$flat/loam-using/scripts/loam-common.sh"
flat_summary_json=$("$flat/loam-ingesting-codebase/scripts/codegraph.sh" walk "$codebase" --summary)

current_epoch=$(stat_epoch "$codebase/src/current.ts")
stale_ingested_epoch=$(date -d '2026-06-24 14:33:00' '+%s')
stale_epoch=$(stat_epoch "$codebase/src/stale.ts")

cat > "$wiki/code/current.md" <<'EOF'
---
source_path: src/current.ts
ingested_at: CURRENT_EPOCH
---
# Current
EOF
sed -i "s/CURRENT_EPOCH/$current_epoch/" "$wiki/code/current.md"
cat > "$wiki/code/stale.md" <<'EOF'
---
source_path: src/stale.ts
ingested_at: STALE_INGESTED_EPOCH
---
# Stale
EOF
sed -i "s/STALE_INGESTED_EPOCH/$stale_ingested_epoch/" "$wiki/code/stale.md"
cat > "$wiki/code/legacy.md" <<'EOF'
---
source_path: src/legacy.ts
ingested_at: 2026-06-24
---
# Legacy
EOF

walk_json=$("$CODEGRAPH" walk "$codebase")
summary_json=$("$CODEGRAPH" walk "$codebase" --summary)
index_json=$("$CODEGRAPH" index "$wiki" --codebase-root "$codebase")
diff_json=$("$CODEGRAPH" diff "$codebase" "$wiki")

wrong_root_output=""
if wrong_root_output=$("$CODEGRAPH" index "$codebase" --codebase-root "$codebase" 2>&1); then
  echo "index accepted workspace root as wiki root" >&2
  exit 1
fi
grep -Fq "did you mean: $codebase/wiki" <<< "$wrong_root_output"

wrong_diff_output=""
if wrong_diff_output=$("$CODEGRAPH" diff "$codebase" "$codebase" 2>&1); then
  echo "diff accepted workspace root as wiki root" >&2
  exit 1
fi
grep -Fq "did you mean: $codebase/wiki" <<< "$wrong_diff_output"

if command -v git >/dev/null 2>&1; then
  no_gitignore_json=$("$CODEGRAPH" walk "$codebase" --no-gitignore)
else
  no_gitignore_json='[]'
fi

WALK_JSON="$walk_json" SUMMARY_JSON="$summary_json" FLAT_SUMMARY_JSON="$flat_summary_json" INDEX_JSON="$index_json" DIFF_JSON="$diff_json" NO_GITIGNORE_JSON="$no_gitignore_json" STALE_EPOCH="$stale_epoch" python3 - <<'PY'
import json, os

walk = json.loads(os.environ['WALK_JSON'])
summary = json.loads(os.environ['SUMMARY_JSON'])
flat_summary = json.loads(os.environ['FLAT_SUMMARY_JSON'])
index = json.loads(os.environ['INDEX_JSON'])
diff = json.loads(os.environ['DIFF_JSON'])
no_gitignore = json.loads(os.environ['NO_GITIGNORE_JSON'])

paths = {item['path'] for item in walk}
assert 'src/current.ts' in paths
assert 'src/stale.ts' in paths
assert 'src/legacy.ts' in paths
assert 'src/new.ts' in paths
assert 'src/semantic.py' in paths
assert 'src/Button.svelte' in paths
assert 'src/empty.ts' not in paths
assert 'src/blank.ts' not in paths
assert 'src/generated.ts' not in paths
assert 'src/large.ts' not in paths
assert 'src/binary.ts' not in paths
assert 'ignored.ts' not in paths
if no_gitignore:
    assert 'ignored.ts' in {item['path'] for item in no_gitignore}

excluded = summary['excluded']
assert summary['total'] == len(walk)
assert summary['by_ext']['ts'] >= 3
assert summary['by_ext']['svelte'] == 1
assert excluded['empty'] >= 2
assert excluded['large'] >= 1
assert excluded['generated_header'] >= 1
assert excluded['binary'] >= 1
assert excluded['gitignore'] >= 1
assert 'node_modules/dummy/index.js' not in paths, "root-level node_modules leaked past **/node_modules/**"
assert 'dist/build.js' not in paths, "root-level dist leaked past **/dist/**"
assert flat_summary['total'] == summary['total'], "flat installed layout could not load shared helpers"

by_source = {item['source_path']: item for item in index}
assert by_source['src/current.ts']['exists'] is True
assert by_source['src/current.ts']['mtime'].isdigit()
assert by_source['src/stale.ts']['exists'] is True
assert by_source['src/stale.ts']['mtime'] == os.environ['STALE_EPOCH']

by_path = {item['path']: item for item in diff}
assert 'src/new.ts' in by_path and by_path['src/new.ts']['reason'] == 'new'
assert 'src/semantic.py' in by_path and by_path['src/semantic.py']['reason'] == 'new'
assert 'src/stale.ts' in by_path and by_path['src/stale.ts']['reason'] == 'stale'
assert by_path['src/stale.ts']['slug'] == 'stale'
assert 'src/legacy.ts' in by_path and by_path['src/legacy.ts']['reason'] == 'stale'
assert 'src/current.ts' not in by_path
assert 'node_modules/dummy/index.js' not in by_path, "root-level node_modules leaked into diff"
assert 'dist/build.js' not in by_path, "root-level dist leaked into diff"
assert 'src/empty.ts' not in by_path
assert 'ignored.ts' not in by_path
PY

# Dual-scan legacy test: stranded source_path: page in entities/ is visible to index
legacy_wiki="$tmp/legacy-wiki"
mkdir -p "$legacy_wiki/entities" "$legacy_wiki/SCHEMA.md.d"
cat > "$legacy_wiki/SCHEMA.md" <<'EOF'
# Schema
EOF
cat > "$legacy_wiki/entities/stranded.ts.md" <<'EOF'
---
source_path: src/stranded.ts
ingested_at: 1700000000
---
# Stranded
EOF
legacy_index_json=$("$CODEGRAPH" index "$legacy_wiki" --codebase-root "$codebase")
LEGACY_INDEX_JSON="$legacy_index_json" python3 - <<'PY'
import json, os
index = json.loads(os.environ['LEGACY_INDEX_JSON'])
by_source = {item['source_path']: item for item in index}
assert 'src/stranded.ts' in by_source, "stranded entities/ page not visible to dual-scan index"
assert by_source['src/stranded.ts']['slug'] == 'stranded.ts'
print("dual-scan legacy: PASS")
PY

# Precedence test: same source_path in both code/ and entities/ — index prefers code/
prec_wiki="$tmp/prec-wiki"
mkdir -p "$prec_wiki/code" "$prec_wiki/entities"
cat > "$prec_wiki/SCHEMA.md" <<'EOF'
# Schema
EOF
cat > "$prec_wiki/code/dup.ts.md" <<'EOF'
---
source_path: src/dup.ts
ingested_at: 1800000000
---
# Dup (code)
EOF
cat > "$prec_wiki/entities/dup.ts.md" <<'EOF'
---
source_path: src/dup.ts
ingested_at: 1700000000
---
# Dup (entities legacy)
EOF
prec_index_json=$("$CODEGRAPH" index "$prec_wiki" --codebase-root "$codebase")
PREC_INDEX_JSON="$prec_index_json" python3 - <<'PY'
import json, os
index = json.loads(os.environ['PREC_INDEX_JSON'])
by_source = {item['source_path']: item for item in index}
assert 'src/dup.ts' in by_source, "dup source_path missing from index"
assert by_source['src/dup.ts']['ingested_at'] == '1800000000', "index did not prefer code/ over entities/ for same source_path"
dups = [item for item in index if item['source_path'] == 'src/dup.ts']
assert len(dups) == 1, f"expected 1 entry for src/dup.ts, got {len(dups)}"
print("precedence: PASS")
PY

# --- Hash-secondary contract tests ---

hash_wiki="$tmp/hash-wiki"
mkdir -p "$hash_wiki/code"
cat > "$hash_wiki/SCHEMA.md" <<'EOF'
# Schema
EOF

# Fixture: legacy-epoch.ts — page with ingested_at (epoch) only, no source_size/content_hash
cat > "$codebase/src/legacy-epoch.ts" <<'EOF'
export const legacy_epoch = 1;
EOF
cat > "$codebase/src/legacy-current.ts" <<'EOF'
export const legacy_current = 1;
EOF

# Fixture: false-stale.ts — content will NOT change, only mtime bumps
cat > "$codebase/src/false-stale.ts" <<'EOF'
export const false_stale = 1;
EOF

# Fixture: changed-size.ts — content will change (size grows)
cat > "$codebase/src/changed-size.ts" <<'EOF'
export const changed_size = 1;
EOF

# Fixture: false-fresh.ts — content will change, mtime stays the same
cat > "$codebase/src/false-fresh.ts" <<'EOF'
export const false_fresh = 1;
EOF

# Compute hashes and sizes for the fixtures
fs_hash=$(file_hash "$codebase/src/false-stale.ts")
fs_size=$(stat_size "$codebase/src/false-stale.ts")
cs_hash=$(file_hash "$codebase/src/changed-size.ts")
cs_size=$(stat_size "$codebase/src/changed-size.ts")
ff_hash=$(file_hash "$codebase/src/false-fresh.ts")
ff_size=$(stat_size "$codebase/src/false-fresh.ts")

# Set mtime on legacy-epoch.ts to a known old time, legacy-current.ts to current
touch -d '2026-06-20 10:00:00' "$codebase/src/legacy-epoch.ts"
legacy_epoch_current=$(stat_epoch "$codebase/src/legacy-epoch.ts")
legacy_current_epoch=$(stat_epoch "$codebase/src/legacy-current.ts")

# false-stale.ts: touch to newer mtime (content unchanged)
touch -d '2026-06-28 12:00:00' "$codebase/src/false-stale.ts"
fs_mtime=$(stat_epoch "$codebase/src/false-stale.ts")
# Page ingested_at is OLDER than fs_mtime → mtime says stale, but hash matches → suppress

# changed-size.ts: overwrite with larger content, set mtime to now (newer than page)
cat > "$codebase/src/changed-size.ts" <<'EOF'
export const changed_size = 1;
export const changed_size_extra = 2;
EOF
touch -d '2026-06-28 12:00:00' "$codebase/src/changed-size.ts"
cs_mtime=$(stat_epoch "$codebase/src/changed-size.ts")

# false-fresh.ts: overwrite content (same size), keep mtime at old value
ff_old_epoch=$(date -d '2026-06-20 10:00:00' '+%s')
cat > "$codebase/src/false-fresh.ts" <<'EOF'
export const false_fresh = 2;
EOF
touch -d '2026-06-20 10:00:00' "$codebase/src/false-fresh.ts"

# Wiki pages
# 1. legacy-epoch: epoch ingested_at, no source_size/content_hash, mtime bumped → stale
cat > "$hash_wiki/code/legacy-epoch.md" <<EOF
---
source_path: src/legacy-epoch.ts
ingested_at: $(date -d '2026-06-18 10:00:00' '+%s')
---
# Legacy Epoch
EOF

# 2. legacy-current: epoch ingested_at, no source_size/content_hash, mtime equal → not stale
cat > "$hash_wiki/code/legacy-current.md" <<EOF
---
source_path: src/legacy-current.ts
ingested_at: $legacy_current_epoch
---
# Legacy Current
EOF

# 3. false-stale: all three fields, mtime bumped, size same, hash same → not stale
cat > "$hash_wiki/code/false-stale.md" <<EOF
---
source_path: src/false-stale.ts
ingested_at: $(date -d '2026-06-24 10:00:00' '+%s')
source_size: $fs_size
content_hash: $fs_hash
---
# False Stale
EOF

# Same as false-stale, but with uppercase stored hash for Windows parity.
cat > "$hash_wiki/code/false-stale-uppercase.md" <<EOF
---
source_path: src/false-stale-uppercase.ts
ingested_at: $(date -d '2026-06-24 10:00:00' '+%s')
source_size: $fs_size
content_hash: $(printf '%s' "$fs_hash" | tr '[:lower:]' '[:upper:]')
---
# False Stale Uppercase
EOF
cp "$codebase/src/false-stale.ts" "$codebase/src/false-stale-uppercase.ts"
touch -d '2026-06-28 12:00:00' "$codebase/src/false-stale-uppercase.ts"

# 4. changed-size: all three fields, size changed → stale
cat > "$hash_wiki/code/changed-size.md" <<EOF
---
source_path: src/changed-size.ts
ingested_at: $(date -d '2026-06-24 10:00:00' '+%s')
source_size: $cs_size
content_hash: $cs_hash
---
# Changed Size
EOF

# 5. false-fresh: content_hash points to old content, mtime matches → default not stale, strict stale
cat > "$hash_wiki/code/false-fresh.md" <<EOF
---
source_path: src/false-fresh.ts
ingested_at: $ff_old_epoch
source_size: $ff_size
content_hash: $ff_hash
---
# False Fresh
EOF

hash_diff_json=$("$CODEGRAPH" diff "$codebase" "$hash_wiki")
hash_strict_json=$("$CODEGRAPH" diff "$codebase" "$hash_wiki" --strict)

HASH_DIFF_JSON="$hash_diff_json" HASH_STRICT_JSON="$hash_strict_json" python3 - <<'PY'
import json, os

diff = json.loads(os.environ['HASH_DIFF_JSON'])
strict = json.loads(os.environ['HASH_STRICT_JSON'])
by_path_diff = {item['path']: item for item in diff}
by_path_strict = {item['path']: item for item in strict}

# 1. legacy-mtime-fallback: epoch ingested_at, no size/hash, mtime bumped → stale
assert 'src/legacy-epoch.ts' in by_path_diff, "legacy-epoch should be stale (mtime bumped, no hash)"
assert by_path_diff['src/legacy-epoch.ts']['reason'] == 'stale', "legacy-epoch reason should be stale"
print("legacy-mtime-fallback: PASS")

# 2. legacy-current-not-stale: epoch ingested_at, no size/hash, mtime equal → not stale
assert 'src/legacy-current.ts' not in by_path_diff, "legacy-current should not be stale (mtime equal, no size/hash regression)"
print("legacy-current-not-stale: PASS")

# 3. false-stale-suppression: all three fields, mtime bumped, size same, hash same → not stale
assert 'src/false-stale.ts' not in by_path_diff, "false-stale should be suppressed (hash matches)"
assert 'src/false-stale-uppercase.ts' not in by_path_diff, "uppercase stored hash should be normalized and suppressed"
print("false-stale-suppression: PASS")

# 4. changed-size-stale: all three fields, size changed → stale
assert 'src/changed-size.ts' in by_path_diff, "changed-size should be stale (size mismatch)"
assert by_path_diff['src/changed-size.ts']['reason'] == 'stale', "changed-size reason should be stale"
print("changed-size-stale: PASS")

# 5. strict-false-fresh: content_hash mismatch, mtime matches → default not stale, strict stale
assert 'src/false-fresh.ts' not in by_path_diff, "false-fresh should NOT be stale in default diff (mtime matches)"
assert 'src/false-fresh.ts' in by_path_strict, "false-fresh should be stale in --strict (hash mismatch)"
assert by_path_strict['src/false-fresh.ts']['reason'] == 'stale', "false-fresh strict reason should be stale"
print("strict-false-fresh: PASS")
PY

grep -Fq 'Cap the work set at 200 files.' "$INGEST_SKILL"
! grep -Fq 'Cap the work set at 100 files.' "$INGEST_SKILL"
grep -Fq 'If `$ARGUMENTS` is empty, default the codebase root to `$(pwd)`.' "$INGEST_SKILL"
grep -Fq 'Default mode is diff-guided ingest: process `new` and `stale` entries from `codegraph diff`.' "$INGEST_SKILL"
grep -Fq 'Do not substitute the codebase root, workspace root, or parent directory.' "$INGEST_SKILL"
grep -Fq 'never report the codebase as fully ingested' "$INGEST_SKILL"
grep -Fq 'Do not proceed from an empty index caused by a bad wiki-root path.' "$INGEST_SKILL"
grep -Fq 'ingested_at: <source-file-mtime-epoch>' "$INGEST_SKILL"
grep -Fq 'Legacy pages with date-only `ingested_at` are stale once' "$INGEST_SKILL"
grep -Fq 'source_size: <bytes>' "$INGEST_SKILL"
grep -Fq 'content_hash: <sha256-hex>' "$INGEST_SKILL"
grep -R -Fq 'ingested_at: <source-file-mtime-epoch>' "$SKILL_DIR/references/templates"

echo "codegraph contract: PASS"
